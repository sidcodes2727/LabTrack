@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #999999
  FontColor #333333
  FontSize 12
}

skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #666666
  FontColor #333333
  FontSize 12
}

skinparam rectangle {
  BackgroundColor #F9F9F9
  BorderColor #D0D0D0
  BorderStyle dashed
  FontColor #AAAAAA
  FontSize 11
}

skinparam ArrowColor #888888
skinparam ArrowFontColor #AAAAAA
skinparam ArrowFontSize 10
skinparam ArrowFontStyle italic

title LabTrack Use Case Diagram

actor Student
actor Admin
actor "Gemini AI"   as AI
actor "Supabase DB" as SB

rectangle "LabTrack System" {

  package "Student use cases" #FAFAFA {
    usecase "Sign up / Login"            as UC_AUTH
    usecase "View Lab Layout"            as UC_VIEW_LAYOUT
    usecase "Search Asset"               as UC_SEARCH
    usecase "View Asset Timeline"        as UC_TIMELINE
    usecase "Submit Complaint"           as UC_SUBMIT
    usecase "Support Complaint (+1)"     as UC_PLUS
  }

  usecase "View Notifications"           as UC_NOTIF

  package "Admin use cases" #FAFAFA {
    usecase "View Dashboard"             as UC_DASH
    usecase "Manage Kanban Status"       as UC_KANBAN
    usecase "Import Assets"              as UC_IMPORT
    usecase "Export Reports"             as UC_EXPORT
    usecase "Monitor SLA / Urgent"       as UC_SLA
  }

  package "Internal use cases" #F4F8FF {
    usecase "Classify Priority"          as UC_AI
    usecase "Persist Data"               as UC_DATA
    usecase "Broadcast Realtime Updates" as UC_RT
  }
}

Student --> UC_AUTH
Student --> UC_VIEW_LAYOUT
Student --> UC_SEARCH
Student --> UC_TIMELINE
Student --> UC_SUBMIT
Student --> UC_PLUS
Student --> UC_NOTIF

Admin --> UC_AUTH
Admin --> UC_DASH
Admin --> UC_KANBAN
Admin --> UC_IMPORT
Admin --> UC_EXPORT
Admin --> UC_NOTIF
Admin --> UC_SLA

UC_SUBMIT .> UC_AI   : <<include>>
UC_SUBMIT .> UC_DATA : <<include>>
UC_SUBMIT .> UC_RT   : <<include>>
UC_PLUS   .> UC_DATA : <<include>>
UC_PLUS   .> UC_RT   : <<include>>
UC_KANBAN .> UC_DATA : <<include>>
UC_KANBAN .> UC_RT   : <<include>>
UC_IMPORT .> UC_DATA : <<include>>

AI --> UC_AI
SB --> UC_DATA

@enduml