@startuml
hide empty methods
skinparam classAttributeIconSize 0

title LabTrack Class Diagram

class User {
  +id: UUID
  +name: String
  +email: String
  +password_hash: String
  +role: user_role
  +created_at: DateTime
}

class Asset {
  +id: UUID
  +system_id: String
  +original_id: String
  +lab: String
  +section: String
  +row_num: Integer
  +position: Integer
  +status: asset_status
  +cpu: String
  +ram: String
  +purchase_date: Date
  +last_maintenance: Date
  +created_at: DateTime
}

class Complaint {
  +id: UUID
  +asset_id: UUID
  +user_id: UUID
  +description: Text
  +priority: priority_level
  +ai_priority: priority_level
  +image_url: String
  +status: complaint_status
  +support_count: Integer
  +supporter_ids: UUID[]
  +created_at: DateTime
  +updated_at: DateTime
}

class Notification {
  +id: UUID
  +title: String
  +message: Text
  +user_id: UUID?
  +role_target: user_role?
  +is_read: Boolean
  +created_at: DateTime
}

class HistoryEvent {
  +id: UUID
  +asset_id: UUID
  +event_type: String
  +details: Text
  +event_date: DateTime
  +created_at: DateTime
}

class AuthMiddleware {
  +authenticate(req,res,next)
  +authorize(...roles)
}

class ComplaintService {
  +classifyComplaint(description)
}

class SocketService {
  +initSocket(server)
  +emitRoleUpdate(role,payload)
  +emitUserUpdate(userId,payload)
}

class SupabaseClient {
  +from(table)
  +storage(bucket)
}

User "1" -- "0..*" Complaint : reports
Asset "1" -- "0..*" Complaint : has
Asset "1" -- "0..*" HistoryEvent : timeline
User "1" -- "0..*" Notification : receives

Complaint ..> ComplaintService : uses AI priority
Complaint ..> SocketService : emits realtime events
Complaint ..> SupabaseClient : persists
AuthMiddleware ..> User : validates JWT user
SocketService ..> AuthMiddleware : verifies socket token

@enduml
