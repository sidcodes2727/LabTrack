@startuml

title LabTrack Deployment Diagram

node "User Device" {
  artifact "Web Browser" as Browser
}

node "Frontend Host" {
  artifact "React App (Vite Build)" as FE
}

node "Backend Host" {
  artifact "Node.js + Express API" as BE
  artifact "Socket.IO Runtime" as WS
}

node "Supabase Cloud" {
  database "PostgreSQL" as PG
  folder "Storage Bucket\ncomplaint-images" as SB
}

node "Google AI Cloud" {
  artifact "Gemini API" as GAI
}

Browser --> FE : HTTPS
FE --> BE : HTTPS REST (/api/*)
FE --> WS : WSS realtime events
BE --> PG : SQL over Supabase SDK
BE --> SB : File upload/download
BE --> GAI : AI classification API

@enduml
