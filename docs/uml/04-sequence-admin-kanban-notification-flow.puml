@startuml
autonumber

title Sequence - Admin Kanban Update and Notification Flow

actor Admin
participant "Admin UI" as UI
participant "Admin API Route\nPATCH /admin/kanban/{id}" as API
database "Supabase DB" as DB
participant "Socket.IO Service" as IO
actor Student

Admin -> UI: Drag card to new column
UI -> API: PATCH status (pending/in_progress/resolved)
API -> DB: Fetch current complaint

alt Invalid transition
  API --> UI: 400 error
  UI --> Admin: Show validation message
else Valid transition
  API -> DB: Update complaint status + updated_at

  alt status == resolved
    API -> DB: Query unresolved complaints for asset
    API -> DB: Update asset status to working/faulty/maintenance
    API -> DB: Insert history('Complaint Resolved')
    API -> DB: Insert reporter notification
  else status in (pending,in_progress)
    API -> DB: Update asset status (faulty/maintenance)
    API -> DB: Insert history('Complaint Status Updated')
  end

  API -> IO: emitRoleUpdate('admin', complaint_updated)
  API -> IO: emitRoleUpdate('student', complaint_updated or complaint_resolved)
  API -> IO: emitUserUpdate(reporter, complaint_updated or complaint_resolved)

  API --> UI: 200 updated card
  IO --> UI: Realtime refresh event
  IO --> Student: Realtime refresh event
  Student -> UI: Open notification bell / popup
end

@enduml
